# Orchestra environment variables
#
# Copy this file to .env (gitignored) and fill in real values.
# Never commit a .env file with real tokens.

# ── Cockpit bearer token ───────────────────────────────────────────────────────
# Token required for mutating cockpit endpoints (pause/resume/retry/cancel/settings).
# If unset, a CSPRNG hex token is generated at boot and logged once at INFO level.
# Set this when you want a stable token across restarts.
ORCHESTRA_COCKPIT_TOKEN=your-cockpit-bearer-token-here

# ── GitHub / tracker token ────────────────────────────────────────────────────
# Least-privilege fine-grained PAT with Issues + Pull Requests read access.
# Used by the tracker adapter (Octokit) to poll issues and reconcile state.
# Referenced in WORKFLOW.md as `api_key: $GITHUB_TOKEN`.
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Copilot agent GitHub tokens (aliases) ─────────────────────────────────────
# The agent subprocess authenticates with its own credential — separate from the
# tracker token above (they are deliberately decoupled: PROJECT_BRIEF §6).
# Fall back to GITHUB_TOKEN if neither is set.
COPILOT_GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
GH_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
