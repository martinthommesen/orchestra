{
  "name": "orchestra",
  "version": "0.0.0",
  "private": true,
  "description": "End-to-end type-safe TypeScript reimplementation of OpenAI's Symphony, on Effect.",
  "type": "module",
  "license": "Apache-2.0",
  "packageManager": "pnpm@11.8.0",
  "engines": {
    "node": ">=22"
  },
  "bin": {
    "orchestra": "./dist/cli/main.js"
  },
  "scripts": {
    "dev": "tsx src/cli/main.ts",
    "dev:cockpit": "vite",
    "build": "tsup && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.cockpit.json",
    "lint": "biome check . && prettier --check \"**/*.{md,yml,yaml,html}\" --ignore-path .gitignore",
    "lint:fix": "biome check --write . && prettier --write \"**/*.{md,yml,yaml,html}\" --ignore-path .gitignore",
    "format": "pnpm lint:fix",
    "test": "vitest run",
    "test:watch": "vitest",
    "check": "pnpm typecheck && pnpm lint && pnpm test && pnpm doctor:score",
    "doctor": "react-doctor --blocking warning",
    "doctor:score": "node scripts/check-react-doctor.mjs"
  },
  "dependencies": {
    "@effect/opentelemetry": "0.63.0",
    "@effect/platform": "^0.96.2",
    "@effect/platform-node": "^0.107.0",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/geist-mono": "^5.2.8",
    "@octokit/rest": "^21.1.1",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/resources": "^2.8.0",
    "@opentelemetry/sdk-logs": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-trace-base": "^2.8.0",
    "@opentelemetry/sdk-trace-node": "^2.8.0",
    "@opentelemetry/sdk-trace-web": "^2.8.0",
    "@opentelemetry/semantic-conventions": "^1.41.1",
    "effect": "^3.21.4",
    "liquidjs": "^10.27.0",
    "lucide-react": "^1.21.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "yaml": "^2.9.0"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "@effect/vitest": "^0.29.0",
    "@types/node": "^26.0.0",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "fast-check": "^4.8.0",
    "prettier": "3.8.4",
    "react-doctor": "0.5.8",
    "tsup": "^8.5.1",
    "tsx": "^4.22.4",
    "typescript": "^6.0.3",
    "vite": "^8.1.0",
    "vitest": "^3.2.6"
  }
}
